# QuoteFlow AI — Root Environment Variables
# ============================================================
# HOW TO USE:
#   cp .env.example .env
#   Then fill in your actual values in .env
#
# ============================================================

# ------------------------------------------------------------
# GEMINI AI  (Required for Backend)
# ------------------------------------------------------------
# Used by the RFQ extraction module (backend/rfq_extractor.py)
# Get your FREE key at:  https://aistudio.google.com/app/apikey
#
# Note: Either GOOGLE_API_KEY or GEMINI_API_KEY can be used.
# GOOGLE_API_KEY is prioritized by the backend.
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# SERVER  (Optional — defaults shown)
# ------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
RELOAD=true

# ------------------------------------------------------------
# FRONTEND CONFIG (Vite)
# ------------------------------------------------------------
# Base URL for the FastAPI backend (used by frontend Axios client)
VITE_API_BASE_URL=http://localhost:8000
