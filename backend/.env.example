# QuoteFlow AI — Environment Variables
# ============================================================
# HOW TO USE:
#   cp backend/.env.example backend/.env
#   Then fill in your actual values in backend/.env
#
# ⚠️  NEVER commit backend/.env to version control.
#     It is already listed in .gitignore.
# ============================================================

# ------------------------------------------------------------
# GEMINI AI  (Required)
# ------------------------------------------------------------
# Used by the RFQ extraction module (backend/rfq_extractor.py)
# to parse uploaded RFQ documents using Google Gemini AI.
#
# Get your FREE key at:  https://aistudio.google.com/app/apikey
# Free tier is sufficient for hackathon / development use.
# Note: Either GOOGLE_API_KEY or GEMINI_API_KEY can be used.
# GOOGLE_API_KEY is prioritized by the backend.
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# SERVER  (Optional — defaults shown)
# ------------------------------------------------------------
# HOST=0.0.0.0
# PORT=8000
# RELOAD=true

# ------------------------------------------------------------
# FRONTEND URL  (Optional — needed only for production CORS)
# ------------------------------------------------------------
# FRONTEND_URL=http://localhost:5173
